---
import ProjectCard from './ProjectCard.astro';

const projects = [
  {
    title: "TaskFlow — Full Stack App",
    description: "Full stack task management application with JWT authentication, REST API built with Express 5 + TypeScript, Prisma ORM, and a Next.js frontend with React Query and Tailwind CSS.",
    tech: ["TypeScript", "Express", "Prisma", "Next.js", "React Query", "Tailwind CSS", "Docker"],
    github: "https://github.com/t0msly3r/task-manager-api",
    demo: null,
    image: "../public/projects/web.png",
    featured: true,
  },
  {
    title: "Push Swap",
    description: "Stack sort algorithm implementation in C to sort data using limited operations and memory.",
    tech: ["C", "Memory Management", "Algorithms"],
    github: "https://github.com/t0msly3r/push_swap",
    demo: null,
    image: "../public/projects/push_swap.gif",
    featured: false,
  },
  {
    title: "VectorStl",
    description: "Custom implementation of a dynamic array (vector) in C++ mimicking STL behavior.",
    tech: ["C++", "OOP"],
    github: "https://github.com/t0msly3r/Stl_vector",
    demo: null,
    image: "../public/projects/Vector-in-C.png",
    featured: false,
  },
  {
    title: "Philosophers Problem",
    description: "Solution to the Dining Philosophers problem using multithreading and synchronization in C.",
    tech: ["C", "Multithreading", "Synchronization"],
    github: "https://github.com/t0msly3r/philosophers",
    demo: null,
    image: "../public/projects/philo.png",
    featured: false,
  },
  {
    title: "Pipe Implementation",
    description: "Custom implementation of UNIX pipes in C for inter-process communication.",
    tech: ["C", "Inter-process Communication"],
    github: "https://github.com/t0msly3r/Pipex",
    demo: null,
    image: "../public/projects/pipe.png",
    featured: false,
  }
];

const featured = projects.filter(p => p.featured);
const rest = projects.filter(p => !p.featured);
---

<section class="projects" id="projects">
  <div class="container">
    <div class="section-header">
      <span class="section-label">04 / projects</span>
      <h2 class="section-title">Things I've Built</h2>
    </div>

    <!-- Featured project -->
    {featured.map(project => (
      <div class="featured-card">
        <div class="featured-image">
          <img src={project.image} alt={project.title} />
          <div class="featured-overlay">
            <div class="project-links">
              <a href={project.github} target="_blank" rel="noopener noreferrer" class="project-link">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path>
                </svg>
                View on GitHub
              </a>
            </div>
          </div>
        </div>
        <div class="featured-content">
          <span class="featured-badge">✦ Featured Project</span>
          <h3>{project.title}</h3>
          <p>{project.description}</p>
          <div class="tech-stack">
            {project.tech.map(t => <span class="tech-tag">{t}</span>)}
          </div>
        </div>
      </div>
    ))}

    <!-- Rest of projects -->
    <div class="projects-grid">
      {rest.map(project => (
        <ProjectCard {...project} />
      ))}
    </div>
  </div>
</section>

<style>
  .projects {
    padding: 7rem 0;
    background: rgba(10, 10, 10, 0.5);
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  /* Header */
  .section-header {
    margin-bottom: 4rem;
  }

  .section-label {
    display: block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #3b82f6;
    margin-bottom: 0.75rem;
  }

  .section-title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    color: #e4e4e7;
    display: inline-block;
  }

  .section-title::after {
    content: '';
    display: block;
    width: 100%;
    height: 3px;
    background: linear-gradient(90deg, #3b82f6, transparent);
    margin-top: 0.5rem;
    border-radius: 2px;
  }

  /* Featured card */
  .featured-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid rgba(59, 130, 246, 0.2);
    background: rgba(20, 20, 30, 0.6);
    margin-bottom: 3rem;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .featured-card:hover {
    border-color: rgba(59, 130, 246, 0.5);
    box-shadow: 0 0 40px rgba(59, 130, 246, 0.08);
  }

  .featured-image {
    position: relative;
    min-height: 280px;
    background: #0f0f1a;
    overflow: hidden;
  }

  .featured-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.85;
    transition: transform 0.4s ease, opacity 0.3s ease;
  }

  .featured-card:hover .featured-image img {
    transform: scale(1.04);
    opacity: 1;
  }

  .featured-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .featured-card:hover .featured-overlay {
    opacity: 1;
  }

  .project-links {
    display: flex;
    gap: 1rem;
  }

  .project-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 1.25rem;
    background: #3b82f6;
    color: white;
    text-decoration: none;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 500;
    transition: background 0.2s ease;
  }

  .project-link:hover {
    background: #2563eb;
  }

  .featured-content {
    padding: 2.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1rem;
  }

  .featured-badge {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #3b82f6;
  }

  .featured-content h3 {
    font-size: 1.6rem;
    font-weight: 700;
    color: #e4e4e7;
    line-height: 1.2;
  }

  .featured-content p {
    font-size: 0.98rem;
    color: #a1a1aa;
    line-height: 1.7;
  }

  .tech-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 0.5rem;
  }

  .tech-tag {
    background: rgba(59, 130, 246, 0.08);
    color: #93c5fd;
    padding: 0.25rem 0.75rem;
    border-radius: 99px;
    font-size: 0.78rem;
    font-weight: 500;
    border: 1px solid rgba(59, 130, 246, 0.15);
  }

  /* Rest grid */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  @media (max-width: 768px) {
    .featured-card {
      grid-template-columns: 1fr;
    }

    .featured-image {
      min-height: 200px;
    }

    .featured-content {
      padding: 1.75rem;
    }

    .projects-grid {
      grid-template-columns: 1fr;
    }
  }
</style>